<!DOCTYPE html>
<html>
<head>
<title>GST Invoice Template</title>
<style>
body { font-family: Arial, sans-serif; padding: 20px; max-width: 800px; margin: auto; }
h1 { text-align: center; }
table { width: 100%; border-collapse: collapse; margin: 20px 0; }
th, td { border: 1px solid #333; padding: 8px; text-align: left; }
th { background: #f0f0f0; }
.total-row { font-weight: bold; }
.header { display: flex; justify-content: space-between; }
.box { border: 1px solid #333; padding: 10px; margin: 10px 0; }
@media print { body { margin: 0; } }
</style>
</head>
<body>
<h1>GST INVOICE</h1>

<div class="header">
<div class="box" style="width:45%">
<strong>Seller:</strong><br>
[Business Name]<br>
[Address]<br>
GSTIN: [XXXXXXXXXXXXXX]
</div>
<div class="box" style="width:45%">
<strong>Invoice Details:</strong><br>
Invoice No.: [___________]<br>
Date: [___________]<br>
State: [State Name]<br>
</div>
</div>

<div class="box">
<strong>Bill To:</strong><br>
[Buyer Name]<br>
[Address]<br>
GSTIN: [XXXXXXXXXXXXXX]
</div>

<table>
<tr>
<th>Sr</th><th>Description</th><th>HSN</th><th>Qty</th><th>Rate</th><th>Taxable</th><th>GST%</th><th>GST</th><th>Total</th>
</tr>
<tr><td>1</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
<tr><td>2</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
<tr><td>3</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
<tr><td>4</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
<tr><td>5</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
</table>

<table>
<tr><td colspan="7">Subtotal</td><td colspan="2">[_______]</td></tr>
<tr><td colspan="7">Discount</td><td colspan="2">[_______]</td></tr>
<tr><td colspan="7">CGST</td><td colspan="2">[_______]</td></tr>
<tr><td colspan="7">SGST</td><td colspan="2">[_______]</td></tr>
<tr><td colspan="7">IGST</td><td colspan="2">[_______]</td></tr>
<tr class="total-row"><td colspan="7">GRAND TOTAL</td><td colspan="2">[_______]</td></tr>
</table>

<div class="box">
<strong>Bank Details:</strong><br>
Bank: [___________]<br>
A/C: [___________]<br>
IFSC: [___________]
</div>

<p style="text-align:center; margin-top:40px;">Authorized Signature</p>
</body>
</html>